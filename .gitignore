scripts/config_secret.py
config_secret.py
config/config.yaml
config/config_secret.yaml
.streamlit/secrets.toml
__pycache__/

# Ruff (local cache + ad-hoc pip --target installs, e.g. agent/sandbox tooling)
.ruff_cache/
_ruff_local/

# pytest-cov / coverage.py
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
