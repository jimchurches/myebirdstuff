benchmarks/map_perf/snapshots/

# Ad-hoc map perf temp output (local; not the curated snapshots/ tree)
benchmarks/map_perf/tmp/

# npm installs under Explorer Streamlit custom components (run npm ci in each frontend/)
node_modules/

